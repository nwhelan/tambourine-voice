# Security group rules for unified Tambourine + TURN deployment

Resources:
  # Pipecat HTTP signaling/API
  TambourineHttpIngress:
    Type: AWS::EC2::SecurityGroupIngress
    Properties:
      GroupId: {"Fn::GetAtt": ["AWSEBSecurityGroup", "GroupId"]}
      IpProtocol: tcp
      FromPort: 8765
      ToPort: 8765
      CidrIp: 0.0.0.0/0

  # WebRTC media ports for direct UDP candidates from the server
  TambourineWebRTCUdpIngress:
    Type: AWS::EC2::SecurityGroupIngress
    Properties:
      GroupId: {"Fn::GetAtt": ["AWSEBSecurityGroup", "GroupId"]}
      IpProtocol: udp
      FromPort: 32768
      ToPort: 65535
      CidrIp: 0.0.0.0/0

  # TURN protocol ports
  Turn3478UdpIngress:
    Type: AWS::EC2::SecurityGroupIngress
    Properties:
      GroupId: {"Fn::GetAtt": ["AWSEBSecurityGroup", "GroupId"]}
      IpProtocol: udp
      FromPort: 3478
      ToPort: 3478
      CidrIp: 0.0.0.0/0

  Turn3478TcpIngress:
    Type: AWS::EC2::SecurityGroupIngress
    Properties:
      GroupId: {"Fn::GetAtt": ["AWSEBSecurityGroup", "GroupId"]}
      IpProtocol: tcp
      FromPort: 3478
      ToPort: 3478
      CidrIp: 0.0.0.0/0

  Turn5349TcpIngress:
    Type: AWS::EC2::SecurityGroupIngress
    Properties:
      GroupId: {"Fn::GetAtt": ["AWSEBSecurityGroup", "GroupId"]}
      IpProtocol: tcp
      FromPort: 5349
      ToPort: 5349
      CidrIp: 0.0.0.0/0

  # TURN relay ports for coturn
  TurnRelayUdpIngress:
    Type: AWS::EC2::SecurityGroupIngress
    Properties:
      GroupId: {"Fn::GetAtt": ["AWSEBSecurityGroup", "GroupId"]}
      IpProtocol: udp
      FromPort: 49152
      ToPort: 65535
      CidrIp: 0.0.0.0/0
